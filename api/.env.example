# Copy to .env.local for local dev (Vercel CLI reads it).
# Never commit .env or .env.local.

# Fine-grained PAT with "Issues: read and write" on the target repo only.
# Generate at: https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=github_pat_REPLACE_ME

# Repo that submissions land in, "owner/name".
GITHUB_REPO=Dsiman/Sadida-AIO

# Origin of the static site that POSTs to /api/submit.
ALLOWED_ORIGIN=http://localhost:8080
